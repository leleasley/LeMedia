{
  "name": "LeMedia",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "build:bot": "npm --workspace apps/bot run build",
    "build": "npm run build:web && npm run build:bot",
    "lint": "npm --workspace apps/web run lint",
    "test": "npm --workspace apps/web run test"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "eslint": "^9.39.4"
  },
  "dependencies": {
    "ajv": "^6.12.4",
    "ajv8": "npm:ajv@^8.18.0",
    "fast-uri": "^3.0.1"
  },
  "overrides": {
    "@duosecurity/duo_universal": {
      "axios": "1.15.0"
    },
    "axios": "1.15.0",
    "minimatch": "10.2.4",
    "flatted": "3.4.2",
    "glob": "13.0.6"
  }
}
